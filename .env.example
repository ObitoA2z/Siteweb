NEXTAUTH_URL=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-64-char-random-secret
NEXTAUTH_SECRET=replace-with-another-64-char-random-secret

DB_PATH=./data/app.sqlite
APP_TIMEZONE=Europe/Paris

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_COOKIE_SECURE=false

# Optional admin 2FA (TOTP base32 secret, e.g. from Google Authenticator setup)
ADMIN_TOTP_SECRET=

# SMTP (leave MAIL_FROM or SMTP_HOST empty to disable outgoing mail)
MAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional Redis rate-limit backend (recommended for multi-instance deployments)
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=lash:ratelimit:

# Trust reverse-proxy headers only when deployed behind a trusted proxy
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_DEPTH=1

# Auth and outbox behavior
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_OUTBOX_MAX_ATTEMPTS=5
ERROR_MONITOR_WEBHOOK_URL=
